# DATABASE CONFIGURATION
# Render Postgres (external URL from Dashboard -> Connect). Append ?sslmode=require for SSL.
# DATABASE_URL and RENDER_DB_URL may be the same string; app reads RENDER_DB_URL first in database.py.
DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxx-a.oregon-postgres.render.com/DATABASE?sslmode=require
RENDER_DB_URL=postgresql://USER:PASSWORD@dpg-xxxx-a.oregon-postgres.render.com/DATABASE?sslmode=require

# SECRET KEYS
SECRET_KEY=your_super_secret_key_for_jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API KEYS (Optional)
OPENWEATHER_API_KEY=your_openweather_key

# --- DBeaver + Render Postgres (external clients) ---
# Use the External Database URL from the Render dashboard (Connect). If SSL mode is wrong, DBeaver often shows EOFException during SSL.
# DBeaver: SSL tab → enable "Use SSL" → set "SSL mode" to "require" (must not be blank).
# Or JDBC URL: jdbc:postgresql://HOST:5432/DBNAME?sslmode=require
# If every client fails SSL from your network, check the DB is "Available" (free DBs expire after 30 days) and Networking allows your IP (or 0.0.0.0/0).
