# Backend Configuration
# ---------------------
# Database URL: sqlite for local, or Render/Postgres (add ?sslmode=require for Render external URL).
# RENDER_DB_URL is optional; if set, backend prefers it over DATABASE_URL (see backend/app/database.py).
DATABASE_URL=sqlite:///./iot_system.db
# RENDER_DB_URL=postgresql://USER:PASSWORD@dpg-xxxx-a.REGION-postgres.render.com/DATABASE?sslmode=require

# Security: Secret key for JWT token generation. Change this in production!
SECRET_KEY=super_secret_key_change_me_123

# Email Service (Gmail SMTP)
EMAIL_USER=alert.iot.capstone@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL (For CORS whitelist)
FRONTEND_URL=http://localhost:5173

# API Keys
# OPENAI_API_KEY=sk-... (If using AI chat features)
